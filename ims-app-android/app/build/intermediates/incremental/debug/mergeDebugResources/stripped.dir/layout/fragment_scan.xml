<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_deep"
    android:padding="24dp">

    <TextView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:text="📷"
        android:textSize="48sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CENTRAL PRODUCT SCANNER"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan a product's barcode or QR code to quickly record receipts or dispatches"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_trigger_scanner"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:text="Launch Camera Scanner"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        app:cornerRadius="@dimen/radius_sm"
        app:elevation="0dp" />

</LinearLayout>
