<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="10dp"
    android:paddingTop="4dp">

    <!-- Stop header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_stop_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop #1: ORD-001"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/badge_stop_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_badge"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_stop_customer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Customer: —"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tv_stop_address"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Address: —"
        android:textSize="12sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="2dp" />

    <!-- Action buttons (visible only when EN_ROUTE and stop is PENDING) -->
    <LinearLayout
        android:id="@+id/stop_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_navigate_stop"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Navigate"
            android:textSize="11.5sp"
            android:textColor="@color/text_primary"
            style="@style/Widget.TTRIMSDriver.Button.Ghost"
            android:layout_marginEnd="6dp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_stop"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1.5"
            android:text="Confirm Delivery"
            android:textSize="11.5sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/color_success"
            app:cornerRadius="@dimen/radius_sm"
            app:elevation="0dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_color"
        android:layout_marginTop="10dp" />
</LinearLayout>
