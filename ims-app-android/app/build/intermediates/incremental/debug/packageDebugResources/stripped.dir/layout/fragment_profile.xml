<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_md">

        <!-- Avatar / Name hero -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/radius_md"
            app:strokeColor="@color/border_color"
            app:strokeWidth="1dp"
            android:layout_marginBottom="@dimen/margin_sm">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/margin_lg"
                android:gravity="center">

                <TextView
                    android:id="@+id/profile_avatar"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:text="DR"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_gradient_header"
                    android:layout_marginBottom="@dimen/margin_sm" />

                <TextView
                    android:id="@+id/profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profile_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logistics Driver"
                    android:textSize="12sp"
                    android:textColor="@color/accent_cyan"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Account details -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/radius_md"
            app:strokeColor="@color/border_color"
            app:strokeWidth="1dp"
            android:layout_marginBottom="@dimen/margin_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Email row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_md"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="EMAIL ADDRESS" style="@style/TextStyle.Label"
                        android:layout_marginBottom="2dp" />
                    <TextView android:id="@+id/profile_email" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="14sp" android:textColor="@color/text_primary" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border_color" android:layout_marginStart="@dimen/margin_md" />

                <!-- Vehicle row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_md">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="VEHICLE NUMBER" style="@style/TextStyle.Label"
                        android:layout_marginBottom="2dp" />
                    <TextView android:id="@+id/profile_vehicle" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="14sp" android:textColor="@color/text_primary" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:text="@string/btn_logout"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/color_danger"
            app:cornerRadius="@dimen/radius_sm"
            app:elevation="0dp" />

        <ProgressBar
            android:id="@+id/profile_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/primary"
            android:visibility="gone"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/margin_sm" />

    </LinearLayout>
</ScrollView>
