<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_md">

        <!-- Status hero card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/radius_md"
            app:strokeColor="@color/border_color"
            app:strokeWidth="1dp"
            android:layout_marginBottom="@dimen/margin_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/margin_lg"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱"
                    android:textSize="36sp"
                    android:layout_marginBottom="@dimen/margin_sm" />

                <TextView
                    android:id="@+id/tv_attendance_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Clocked In"
                    android:textSize="18sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_elapsed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHIFT DURATION"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_elapsed_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textSize="32sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Clock In button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clock_in"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:text="@string/btn_clock_in"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/color_success"
            app:cornerRadius="@dimen/radius_sm"
            app:elevation="0dp"
            android:layout_marginBottom="@dimen/margin_sm" />

        <!-- Clock Out button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clock_out"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:text="@string/btn_clock_out"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/color_danger"
            app:cornerRadius="@dimen/radius_sm"
            app:elevation="0dp"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/margin_md" />

        <!-- Info note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPS tracking automatically runs while your shift is active.\nBreadcrumbs are sent every 30 seconds to the dispatch center."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:padding="@dimen/margin_md"
            android:background="@drawable/bg_card" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/attendance_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/primary"
            android:visibility="gone"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/margin_md" />

    </LinearLayout>
</ScrollView>
