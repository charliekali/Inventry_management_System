<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRODUCTION RUN ENGINE"
        style="@style/TextStyle.Label"
        android:layout_marginBottom="12dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.TTRIMSDriver.Card"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Recipe Spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Target Recipe Formula"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinner_run_recipe"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_badge"
                android:layout_marginBottom="12dp" />

            <!-- Input Batch Size -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_batch_size"
                style="@style/Widget.TTRIMSDriver.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Target Batch Size (KG)"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_batch_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_prod_run"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="Trigger Batch Production Run"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/radius_sm"
                app:elevation="0dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BATCH RUN HISTORY"
        style="@style/TextStyle.Label"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_production_runs"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
