<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- Launcher logo container -->
    <TextView
        android:id="@+id/splash_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="📦"
        android:textSize="52sp"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/splash_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TTRIMS"
        android:textSize="32sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/splash_icon"
        app:layout_constraintBottom_toTopOf="@id/splash_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WAREHOUSE &amp; INVENTORY"
        android:textSize="11sp"
        android:textColor="@color/accent_cyan"
        android:textStyle="bold"
        android:letterSpacing="0.16"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/splash_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:indeterminateTint="@color/accent_cyan"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
